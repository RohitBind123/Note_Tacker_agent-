# Copy to .env and fill in. NEVER commit the real .env.

# --- App config ---
APP_ENV=development
LOG_LEVEL=INFO
LOG_JSON=false
CALENDAR_POLL_INTERVAL_SECONDS=60
SCHEDULER_INTERVAL_SECONDS=30
DISPATCH_LEAD_SECONDS=60
BOT_STATUS_POLL_INTERVAL_SECONDS=10
# Grace after a meeting's scheduled end before the scheduler force-stops a
# still-active bot (so it never lingers in an empty Meet).
MEETING_END_GRACE_SECONDS=120
# Who gets the insight email: "organizer" (default) or "all_attendees"
# (organizer + every invited guest, excluding the bot itself).
EMAIL_RECIPIENTS=organizer

# --- Gemini (Google AI Studio) ---
GEMINI_API_KEY=your-gemini-key
GEMINI_MODEL=gemini-2.5-flash
GEMINI_API_BASE=https://generativelanguage.googleapis.com/v1beta

# --- Vexa (cloud meeting bot API) ---
VEXA_API_BASE=https://api.cloud.vexa.ai
VEXA_API_KEY=vxa_bot_your-key
VEXA_TRANSCRIPTION_TOKEN=vxa_tx_your-token
# Bot leaves this many seconds after everyone else left (Vexa default 900s is too slow)
VEXA_LEAVE_WHEN_ALONE_SECONDS=45
VEXA_NO_ONE_JOINED_TIMEOUT_SECONDS=300

# --- Neon Postgres ---
DATABASE_URL=postgresql://user:pass@ep-xxx-pooler.region.aws.neon.tech/neondb?sslmode=require
DATABASE_URL_DIRECT=postgresql://user:pass@ep-xxx.region.aws.neon.tech/neondb?sslmode=require

# --- Google Cloud (Calendar read + Gmail send) ---
GCP_PROJECT_ID=your-project-id
GCP_PROJECT_NUMBER=000000000000
BOT_GOOGLE_EMAIL=centralagentai@gmail.com
GOOGLE_OAUTH_CLIENT_ID=your-client-id.apps.googleusercontent.com
GOOGLE_OAUTH_CLIENT_SECRET=your-client-secret
GOOGLE_OAUTH_REFRESH_TOKEN=your-refresh-token

# --- Gmail invite scanner ---
# Detects Meet invites sent via "Add people" in meet.google.com (no Calendar event created).
# STEP 1: Re-mint the refresh token with gmail.readonly scope (see docs/CHALLENGES.md rollout).
# STEP 2: Set GMAIL_SCAN_ENABLED=true and redeploy.
GMAIL_SCAN_ENABLED=false
GMAIL_SCAN_INTERVAL_SECONDS=90
GMAIL_SCAN_MAX_RESULTS=25
# Scoped to meetings-noreply@google.com (Google Meet's instant-invite sender) so the
# scanner only picks up meetings with NO Calendar event. Calendar invitations come from
# the organizer and are handled by the poller — excluding them here avoids double dispatch.
GMAIL_SCAN_QUERY=from:meetings-noreply@google.com "meet.google.com" newer_than:1d

# --- Webhooks / public URL (dev via ngrok) ---
NGROK_AUTHTOKEN=your-ngrok-token
PUBLIC_BASE_URL=
# Calendar push (events.watch) — OFF in dev (needs a verified domain). Poller is primary.
CALENDAR_PUSH_ENABLED=false
CALENDAR_WEBHOOK_TOKEN=set-a-random-secret
